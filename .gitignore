# --- Line Glide: keep the GitHub repo focused on the deployable game ---

# Local sandbox tooling & gateway (not needed on Vercel)
/.zscripts/
/Caddyfile
/download/

# Sample / demo code not part of the game (imports socket.io which isn't installed)
/examples/
/mini-services/

# Database (the game is fully client-side; avoid shipping SQLite binaries
# and avoid Prisma generated-client build issues on Vercel)
/db/
/prisma/
/src/lib/db.ts
*.db
*.db-journal

# Debug screenshots created during development
/preview-*.png
/p-*.png
/*.png